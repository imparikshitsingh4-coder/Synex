<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>My Synex — Your AI Companion</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Playfair+Display:wght@400;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
  :root {
    --bg-void: #080808;
    --bg-deep: #0e0e0e;
    --bg-surface: #141414;
    --bg-elevated: #1a1a1a;
    --bg-hover: #222222;
    --border: rgba(255,255,255,0.06);
    --border-glow: rgba(180,160,255,0.2);
    --accent: #b4a0ff;
    --accent-dim: rgba(180,160,255,0.12);
    --accent-glow: rgba(180,160,255,0.35);
    --gold: #c9a84c;
    --gold-dim: rgba(201,168,76,0.12);
    --text-primary: #f0f0f0;
    --text-secondary: #888;
    --text-muted: #555;
    --radius: 16px;
    --radius-sm: 10px;
    --font-display: 'Playfair Display', serif;
    --font-body: 'Space Grotesk', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    height: 100%;
    background: var(--bg-void);
    color: var(--text-primary);
    font-family: var(--font-body);
    overflow: hidden;
  }

  /* ── Ambient background ── */
  #ambient {
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background:
      radial-gradient(ellipse 60% 40% at 20% 10%, rgba(100,80,200,0.07) 0%, transparent 60%),
      radial-gradient(ellipse 50% 30% at 80% 80%, rgba(180,140,255,0.05) 0%, transparent 60%),
      radial-gradient(ellipse 30% 20% at 50% 50%, rgba(201,168,76,0.03) 0%, transparent 60%);
  }

  /* ── Layout ── */
  #app { display: flex; height: 100vh; position: relative; z-index: 1; }

  /* ── Sidebar ── */
  #sidebar {
    width: 260px; min-width: 260px;
    background: var(--bg-deep);
    border-right: 1px solid var(--border);
    display: flex; flex-direction: column;
    transition: transform .3s ease;
    position: relative; z-index: 10;
  }

  .sidebar-logo {
    padding: 22px 20px 18px;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 10px;
  }
  .logo-icon {
    width: 36px; height: 36px; border-radius: 10px;
    background: linear-gradient(135deg, var(--accent), var(--gold));
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; flex-shrink: 0;
  }
  .logo-text { font-family: var(--font-display); font-size: 20px; font-weight: 700;
    background: linear-gradient(120deg, var(--accent), var(--gold));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .logo-badge { font-size: 9px; color: var(--gold); border: 1px solid rgba(201,168,76,0.4);
    padding: 2px 6px; border-radius: 20px; margin-left: auto; letter-spacing:.5px; }

  .sidebar-section { padding: 14px 12px 4px; }
  .sidebar-section-label { font-size: 10px; color: var(--text-muted); letter-spacing: 1.5px;
    text-transform: uppercase; padding: 0 8px 8px; }

  .new-chat-btn {
    margin: 14px 12px 6px;
    background: linear-gradient(135deg, rgba(180,160,255,0.15), rgba(201,168,76,0.1));
    border: 1px solid var(--border-glow);
    border-radius: var(--radius-sm); padding: 10px 14px;
    color: var(--text-primary); font-family: var(--font-body); font-size: 13px;
    cursor: pointer; display: flex; align-items: center; gap: 8px; width: calc(100% - 24px);
    transition: all .2s;
  }
  .new-chat-btn:hover { background: linear-gradient(135deg, rgba(180,160,255,0.25), rgba(201,168,76,0.15));
    box-shadow: 0 0 20px var(--accent-glow); }

  .mode-pills { display: flex; gap: 6px; padding: 6px 12px 10px; flex-wrap: wrap; }
  .mode-pill {
    font-size: 11px; padding: 5px 10px; border-radius: 20px; cursor: pointer;
    border: 1px solid var(--border); color: var(--text-secondary); background: transparent;
    font-family: var(--font-body); transition: all .2s;
  }
  .mode-pill:hover, .mode-pill.active {
    border-color: var(--accent); color: var(--accent);
    background: var(--accent-dim);
  }

  .nav-item {
    display: flex; align-items: center; gap: 10px; padding: 9px 20px;
    color: var(--text-secondary); font-size: 13px; cursor: pointer;
    border-radius: var(--radius-sm); margin: 1px 8px; transition: all .2s;
    border: 1px solid transparent;
  }
  .nav-item:hover { background: var(--bg-elevated); color: var(--text-primary); border-color: var(--border); }
  .nav-item.active { background: var(--accent-dim); color: var(--accent); border-color: var(--border-glow); }
  .nav-icon { font-size: 15px; width: 20px; text-align: center; }

  .history-list { flex: 1; overflow-y: auto; padding: 4px 8px; }
  .history-list::-webkit-scrollbar { width: 3px; }
  .history-list::-webkit-scrollbar-thumb { background: var(--bg-hover); border-radius: 3px; }
  .history-item {
    padding: 8px 12px; border-radius: var(--radius-sm); cursor: pointer;
    color: var(--text-secondary); font-size: 12px; transition: all .2s;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    border: 1px solid transparent; margin-bottom: 2px;
  }
  .history-item:hover { background: var(--bg-elevated); color: var(--text-primary); border-color: var(--border); }

  .sidebar-footer {
    border-top: 1px solid var(--border); padding: 12px;
  }
  .user-pill {
    display: flex; align-items: center; gap: 10px; padding: 8px 10px;
    background: var(--bg-elevated); border-radius: var(--radius-sm); border: 1px solid var(--border);
    cursor: pointer; transition: all .2s;
  }
  .user-pill:hover { border-color: var(--border-glow); }
  .user-avatar { width: 28px; height: 28px; border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--gold));
    display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; }
  .user-name { font-size: 12px; font-weight: 500; flex: 1; }
  .user-plan { font-size: 10px; color: var(--gold); }

  /* ── Main area ── */
  #main { flex: 1; display: flex; flex-direction: column; min-width: 0; position: relative; }

  /* ── Topbar ── */
  #topbar {
    height: 56px; background: var(--bg-deep); border-bottom: 1px solid var(--border);
    display: flex; align-items: center; padding: 0 20px; gap: 12px; flex-shrink: 0;
  }
  .menu-btn { background: none; border: 1px solid var(--border); border-radius: 8px;
    color: var(--text-secondary); cursor: pointer; padding: 6px 8px; font-size: 14px; display: none; }
  .topbar-title { font-family: var(--font-display); font-size: 15px; color: var(--text-secondary); flex: 1; }
  .topbar-actions { display: flex; gap: 8px; }
  .icon-btn {
    background: none; border: 1px solid var(--border); border-radius: 8px; color: var(--text-secondary);
    cursor: pointer; padding: 6px 10px; font-size: 13px; transition: all .2s; white-space: nowrap;
    font-family: var(--font-body);
  }
  .icon-btn:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }
  .icon-btn.danger:hover { border-color: #ff6b6b; color: #ff6b6b; background: rgba(255,107,107,0.1); }

  /* ── Voice mode overlay ── */
  #voice-overlay {
    position: fixed; inset: 0; z-index: 100;
    background: rgba(8,8,8,0.97);
    display: none; flex-direction: column; align-items: center; justify-content: center; gap: 32px;
  }
  #voice-overlay.active { display: flex; }
  .voice-orb-container { position: relative; width: 180px; height: 180px; }
  .voice-orb {
    width: 180px; height: 180px; border-radius: 50%; position: absolute;
    background: radial-gradient(circle, rgba(180,160,255,0.3) 0%, rgba(100,80,200,0.15) 40%, transparent 70%);
    display: flex; align-items: center; justify-content: center;
  }
  .voice-orb-inner {
    width: 90px; height: 90px; border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--gold));
    display: flex; align-items: center; justify-content: center; font-size: 32px;
    box-shadow: 0 0 40px var(--accent-glow);
  }
  .voice-ring {
    position: absolute; inset: 0; border-radius: 50%;
    border: 2px solid rgba(180,160,255,0.3);
    animation: voice-pulse 2s ease-in-out infinite;
  }
  .voice-ring:nth-child(2) { inset: -20px; animation-delay: 0.5s; opacity: .5; }
  .voice-ring:nth-child(3) { inset: -40px; animation-delay: 1s; opacity: .25; }
  @keyframes voice-pulse { 0%,100% { transform: scale(1); opacity: .3; } 50% { transform: scale(1.05); opacity: .7; } }
  .voice-status { font-size: 13px; color: var(--text-secondary); letter-spacing: 1px; text-align: center; }
  .voice-transcript { max-width: 400px; text-align: center; font-size: 16px; color: var(--text-primary);
    min-height: 48px; font-style: italic; }
  .voice-controls { display: flex; gap: 16px; }
  .voice-ctrl-btn {
    background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 12px;
    color: var(--text-secondary); cursor: pointer; padding: 12px 20px; font-size: 13px;
    font-family: var(--font-body); transition: all .2s;
  }
  .voice-ctrl-btn:hover { border-color: var(--accent); color: var(--accent); }
  .voice-ctrl-btn.end { border-color: rgba(255,107,107,0.4); color: #ff6b6b; }
  .voice-ctrl-btn.end:hover { background: rgba(255,107,107,0.1); }

  /* ── Wake word indicator ── */
  #wake-indicator {
    position: fixed; bottom: 90px; right: 20px; z-index: 50;
    background: var(--bg-elevated); border: 1px solid var(--border);
    border-radius: 30px; padding: 8px 14px; font-size: 11px; color: var(--text-muted);
    display: flex; align-items: center; gap: 6px; cursor: pointer; transition: all .2s;
  }
  #wake-indicator:hover { border-color: var(--accent); color: var(--accent); }
  #wake-indicator.listening { border-color: rgba(100,220,100,0.4); color: #64dc64; }
  .wake-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--text-muted); }
  #wake-indicator.listening .wake-dot { background: #64dc64; animation: blink 1s infinite; }
  @keyframes blink { 0%,100% { opacity: 1; } 50% { opacity: .3; } }

  /* ── Chat area ── */
  #chat-area {
    flex: 1; overflow-y: auto; padding: 24px 0;
    display: flex; flex-direction: column; gap: 0;
  }
  #chat-area::-webkit-scrollbar { width: 4px; }
  #chat-area::-webkit-scrollbar-thumb { background: var(--bg-hover); border-radius: 4px; }

  /* ── Empty state ── */
  #empty-state {
    flex: 1; display: flex; flex-direction: column; align-items: center;
    justify-content: center; padding: 40px 20px; gap: 32px;
  }
  .empty-logo { font-family: var(--font-display); font-size: 42px; font-weight: 700;
    background: linear-gradient(120deg, var(--accent), var(--gold));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .empty-sub { color: var(--text-muted); font-size: 14px; text-align: center; max-width: 400px; line-height: 1.7; }
  .capability-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; max-width: 520px; width: 100%; }
  .cap-card {
    background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius-sm);
    padding: 14px 16px; cursor: pointer; transition: all .25s;
  }
  .cap-card:hover { border-color: var(--border-glow); background: var(--bg-elevated); transform: translateY(-1px); }
  .cap-icon { font-size: 20px; margin-bottom: 6px; }
  .cap-title { font-size: 12px; font-weight: 600; color: var(--text-primary); margin-bottom: 3px; }
  .cap-desc { font-size: 11px; color: var(--text-muted); line-height: 1.5; }

  /* ── Messages ── */
  .msg-wrapper { padding: 6px 24px; max-width: 860px; margin: 0 auto; width: 100%; }
  .msg-wrapper.user { display: flex; justify-content: flex-end; }
  .msg-wrapper.assistant { display: flex; justify-content: flex-start; gap: 10px; }

  .msg-avatar {
    width: 30px; height: 30px; border-radius: 50%; flex-shrink: 0;
    background: linear-gradient(135deg, var(--accent), var(--gold));
    display: flex; align-items: center; justify-content: center; font-size: 13px;
    margin-top: 4px;
  }

  .msg-bubble {
    max-width: 75%; padding: 12px 16px; border-radius: 14px; font-size: 14px; line-height: 1.7;
    position: relative; word-break: break-word;
  }
  .msg-wrapper.user .msg-bubble {
    background: linear-gradient(135deg, rgba(180,160,255,0.2), rgba(201,168,76,0.12));
    border: 1px solid var(--border-glow);
    border-bottom-right-radius: 4px;
    color: var(--text-primary);
  }
  .msg-wrapper.assistant .msg-bubble {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-bottom-left-radius: 4px;
    color: var(--text-primary);
  }

  .msg-meta { display: flex; align-items: center; gap: 8px; margin-top: 6px; }
  .msg-time { font-size: 10px; color: var(--text-muted); }
  .msg-action-btn {
    font-size: 11px; color: var(--text-muted); background: none; border: none;
    cursor: pointer; padding: 2px 5px; border-radius: 4px; font-family: var(--font-body);
    transition: color .2s;
  }
  .msg-action-btn:hover { color: var(--accent); }

  /* Code blocks */
  pre { background: var(--bg-void); border: 1px solid var(--border); border-radius: 10px;
    padding: 14px; overflow-x: auto; margin: 10px 0; }
  code { font-family: var(--font-mono); font-size: 12px; color: #c9a84c; }
  pre code { color: var(--text-primary); }

  /* Inline formatting */
  strong { color: var(--accent); font-weight: 600; }
  em { color: var(--text-secondary); }
  .msg-bubble ul, .msg-bubble ol { padding-left: 18px; margin: 6px 0; }
  .msg-bubble li { margin-bottom: 3px; }
  .msg-bubble p + p { margin-top: 8px; }
  .msg-bubble h1,.msg-bubble h2,.msg-bubble h3 { color: var(--accent); margin: 10px 0 4px; }

  /* ── Typing indicator ── */
  .typing-dots { display: flex; gap: 4px; padding: 4px 0; }
  .typing-dots span { width: 7px; height: 7px; border-radius: 50%; background: var(--accent);
    animation: bounce 1.2s infinite; }
  .typing-dots span:nth-child(2) { animation-delay: .2s; }
  .typing-dots span:nth-child(3) { animation-delay: .4s; }
  @keyframes bounce { 0%,80%,100% { transform: scale(.6); opacity:.4; } 40% { transform: scale(1); opacity:1; } }

  /* ── File chips ── */
  .file-preview-area { display: flex; gap: 8px; flex-wrap: wrap; padding: 8px 20px 0; max-width: 860px; margin: 0 auto; width: 100%; }
  .file-chip {
    display: flex; align-items: center; gap: 6px; background: var(--bg-elevated);
    border: 1px solid var(--border); border-radius: 8px; padding: 6px 10px; font-size: 12px; color: var(--text-secondary);
  }
  .file-chip-remove { cursor: pointer; color: var(--text-muted); font-size: 14px; line-height: 1; }
  .file-chip-remove:hover { color: #ff6b6b; }

  /* ── Input bar ── */
  #input-area {
    border-top: 1px solid var(--border); padding: 16px 20px;
    background: var(--bg-deep); flex-shrink: 0;
  }
  #input-wrap {
    max-width: 860px; margin: 0 auto;
    background: var(--bg-surface); border: 1px solid var(--border);
    border-radius: 18px; overflow: hidden; transition: border-color .2s, box-shadow .2s;
  }
  #input-wrap:focus-within { border-color: var(--border-glow); box-shadow: 0 0 20px rgba(180,160,255,0.1); }

  #input-toolbar { display: flex; align-items: center; gap: 4px; padding: 8px 12px 0; }
  .toolbar-btn {
    background: none; border: 1px solid transparent; border-radius: 6px;
    color: var(--text-muted); cursor: pointer; padding: 5px 8px; font-size: 13px;
    font-family: var(--font-body); transition: all .2s; white-space: nowrap;
  }
  .toolbar-btn:hover { color: var(--accent); background: var(--accent-dim); border-color: var(--border-glow); }

  #message-input {
    width: 100%; background: none; border: none; outline: none;
    color: var(--text-primary); font-family: var(--font-body); font-size: 14px;
    resize: none; padding: 10px 14px; min-height: 48px; max-height: 160px;
    line-height: 1.6; overflow-y: auto;
  }
  #message-input::placeholder { color: var(--text-muted); }
  #message-input::-webkit-scrollbar { width: 3px; }
  #message-input::-webkit-scrollbar-thumb { background: var(--bg-hover); }

  #input-footer { display: flex; align-items: center; gap: 8px; padding: 6px 12px 10px; }
  #char-count { font-size: 11px; color: var(--text-muted); flex: 1; }
  .model-badge { font-size: 10px; color: var(--gold); border: 1px solid rgba(201,168,76,0.3);
    padding: 3px 8px; border-radius: 20px; }

  #send-btn {
    background: linear-gradient(135deg, var(--accent), #8b72e0);
    border: none; border-radius: 10px; color: white; cursor: pointer;
    width: 36px; height: 36px; font-size: 15px; display: flex;
    align-items: center; justify-content: center; transition: all .2s; flex-shrink: 0;
    box-shadow: 0 2px 12px rgba(180,160,255,0.3);
  }
  #send-btn:hover { transform: scale(1.05); box-shadow: 0 4px 20px var(--accent-glow); }
  #send-btn:disabled { opacity: .4; cursor: not-allowed; transform: none; }

  /* ── Panels ── */
  .panel-overlay {
    position: fixed; inset: 0; z-index: 80; background: rgba(0,0,0,0.7);
    display: none; align-items: center; justify-content: center;
    padding: 20px;
  }
  .panel-overlay.active { display: flex; }

  .panel {
    background: var(--bg-deep); border: 1px solid var(--border);
    border-radius: 20px; max-width: 580px; width: 100%; max-height: 80vh;
    overflow-y: auto; padding: 28px;
  }
  .panel::-webkit-scrollbar { width: 3px; }
  .panel::-webkit-scrollbar-thumb { background: var(--bg-hover); }
  .panel-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
  .panel-title { font-family: var(--font-display); font-size: 20px;
    background: linear-gradient(120deg, var(--accent), var(--gold));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .panel-close { background: none; border: 1px solid var(--border); border-radius: 8px;
    color: var(--text-muted); cursor: pointer; padding: 6px 10px; font-size: 16px; transition: all .2s; }
  .panel-close:hover { border-color: #ff6b6b; color: #ff6b6b; }

  .setting-row { display: flex; align-items: center; justify-content: space-between;
    padding: 14px 0; border-bottom: 1px solid var(--border); }
  .setting-row:last-child { border-bottom: none; }
  .setting-label { font-size: 13px; font-weight: 500; }
  .setting-desc { font-size: 11px; color: var(--text-muted); margin-top: 2px; }

  .toggle {
    width: 40px; height: 22px; border-radius: 11px; background: var(--bg-hover);
    border: 1px solid var(--border); position: relative; cursor: pointer; transition: all .3s;
    flex-shrink: 0;
  }
  .toggle.on { background: linear-gradient(135deg, var(--accent), #8b72e0); border-color: var(--accent); }
  .toggle::after { content: ''; position: absolute; width: 16px; height: 16px; border-radius: 50%;
    background: white; top: 2px; left: 2px; transition: left .3s;
    box-shadow: 0 1px 4px rgba(0,0,0,0.3); }
  .toggle.on::after { left: 20px; }

  .select-input, .text-input {
    background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 8px;
    color: var(--text-primary); font-family: var(--font-body); font-size: 12px;
    padding: 6px 10px; outline: none; transition: border-color .2s;
  }
  .select-input { cursor: pointer; }
  .select-input:focus, .text-input:focus { border-color: var(--accent); }

  /* ── Image modal ── */
  #img-modal {
    position: fixed; inset: 0; z-index: 200; background: rgba(0,0,0,0.9);
    display: none; align-items: center; justify-content: center;
  }
  #img-modal.active { display: flex; }
  #img-modal img { max-width: 90vw; max-height: 90vh; border-radius: 12px; }
  #img-modal-close { position: absolute; top: 20px; right: 20px; background: var(--bg-elevated);
    border: 1px solid var(--border); border-radius: 8px; color: white; cursor: pointer;
    padding: 8px 12px; font-size: 16px; }

  /* ── Toast ── */
  #toast {
    position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%);
    background: var(--bg-elevated); border: 1px solid var(--border-glow);
    border-radius: 10px; padding: 10px 18px; font-size: 13px; color: var(--text-primary);
    z-index: 300; opacity: 0; transition: opacity .3s; pointer-events: none;
  }
  #toast.show { opacity: 1; }

  /* ── Suggestions ── */
  .suggestion-chips { display: flex; gap: 8px; padding: 0 24px 12px; flex-wrap: wrap;
    max-width: 860px; margin: 0 auto; width: 100%; }
  .sugg-chip {
    font-size: 12px; padding: 6px 12px; border-radius: 20px; cursor: pointer;
    border: 1px solid var(--border); color: var(--text-secondary); background: var(--bg-surface);
    font-family: var(--font-body); transition: all .2s; white-space: nowrap;
  }
  .sugg-chip:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }

  /* ── Think indicator ── */
  .think-block {
    background: var(--bg-void); border-left: 2px solid var(--gold);
    border-radius: 0 8px 8px 0; padding: 8px 12px; margin-bottom: 10px;
    font-size: 12px; color: var(--text-muted); font-style: italic;
  }

  /* ── Image generation ── */
  .gen-img-placeholder {
    width: 100%; max-width: 320px; aspect-ratio: 1;
    background: linear-gradient(135deg, var(--bg-elevated), var(--bg-hover));
