<script>
// ── State ──
const state = {
  messages: [],
  history: JSON.parse(localStorage.getItem('synex_history') || '[]'),
  settings: JSON.parse(localStorage.getItem('synex_settings') || '{}'),
  attachments: [],
  mode: 'chat',
  deepThink: false,
  webSearch: true,
  wakeWordActive: false,
  wakeRecognition: null,
  voiceRecognition: null,
  synth: window.speechSynthesis,
  apiKey: 'AQ.Ab8RN6Imd__UJGP35FQ2XiNCf8XdsV1USRHjCcqA4-VGkPqzmA',
  currentConvId: null,
  isTyping: false,
};

// ── Init ──
function init() {
  loadSettings();
  renderHistory();
  // Start wake word if enabled
  if (state.settings.wakeWord !== false) {
    setTimeout(startWakeWord, 1000);
  }
  applySettingToggles();
   Load saved API key
  const savedKey = localStorage.getItem('synex_api_key') || '';
  if (savedKey) {
    state.apiKey = savedKey;
   document.getElementById('api-key-input').value = savedKey;
  }
  document.getElementById('api-key-input').addEventListener('change', (e) => {
    state.apiKey = e.target.value.trim();
    localStorage.setItem('synex_api_key', state.apiKey);
    showToast('API key saved');
  });
}

function loadSettings() {
  const s = state.settings;
  state.webSearch = s.webSearch !== false;
  state.deepThink = s.deepThink === true;
  if (document.getElementById('resp-len')) {
    document.getElementById('resp-len').value = s.responseLength || 'balanced';
    document.getElementById('personality').value = s.personality || 'assistant';
    if (s.temperature !== undefined) document.getElementById('temp-slider').value = s.temperature;
  }
}

function applySettingToggles() {
  const s = state.settings;
  const map = {
    'deepThink': 't-think',
    'webSearch': 't-web',
    'wakeWord': 't-wake',
    'autoRead': 't-read',
    'memory': 't-mem',
    'codeHL': 't-code'
  };
  for (const [key, id] of Object.entries(map)) {
    const el = document.getElementById(id);
    if (!el) continue;
    const defaultOn = ['webSearch','wakeWord','memory','codeHL'].includes(key);
    const on = s[key] !== undefined ? s[key] : defaultOn;
    if (on) el.classList.add('on'); else el.classList.remove('on');
  }
  updateWebBtn();
  updateThinkBtn();
}

// ── Settings ──
function toggleSetting(el, key) {
  el.classList.toggle('on');
  const on = el.classList.contains('on');
  state.settings[key] = on;
  localStorage.setItem('synex_settings', JSON.stringify(state.settings));
  if (key === 'wakeWord') {
    on ? startWakeWord() : stopWakeWord();
  }
  if (key === 'webSearch') { state.webSearch = on; updateWebBtn(); }
  if (key === 'deepThink') { state.deepThink = on; updateThinkBtn(); }
  showToast(key + (on ? ' enabled' : ' disabled'));
}

// ── Mode ──
function setMode(el, mode) {
  document.querySelectorAll('.mode-pill').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  state.mode = mode;
  const ph = {
    chat: 'Message My Synex…',
    code: 'Describe the code you want or paste code to analyze…',
    image: 'Describe an image to generate…',
    docs: 'Upload a document or describe what to write…',
    research: 'What do you want to research?'
  };
  document.getElementById('message-input').placeholder = (ph[mode] || 'Message My Synex…') + ' (Shift+Enter for new line)';
}

function setNav(el, section) {
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  el.classList.add('active');
  if (section === 'voice') { startVoice(); return; }
  if (section === 'image-gen') {
    quickPrompt('Generate a stunning image of: ');
    document.getElementById('message-input').focus();
  }
  if (section === 'code-editor') {
    setMode(document.querySelector('.mode-pill:nth-child(2)'), 'code');
    quickPrompt('Write code to ');
    document.getElementById('message-input').focus();
  }
  if (section === 'translate') {
    document.getElementById('message-input').value = 'Translate to [language]: ';
    document.getElementById('message-input').focus();
  }
  if (section === 'summarize') {
    document.getElementById('message-input').value = 'Summarize the following: ';
    document.getElementById('message-input').focus();
  }
  if (section === 'memory') showMemory();
  if (section === 'file-analysis') document.getElementById('file-input').click();
}

// ── Wake word ──
function startWakeWord() {
  if (!('webkitSpeechRecognition' in window) && !('SpeechRecognition' in window)) return;
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  state.wakeRecognition = new SR();
  state.wakeRecognition.continuous = true;
  state.wakeRecognition.interimResults = true;
  state.wakeRecognition.lang = 'en-US';
  state.wakeRecognition.onresult = (e) => {
    const t = Array.from(e.results).map(r => r[0].transcript).join('').toLowerCase();
    if (t.includes('hey synex') || t.includes('hey synax') || t.includes('hi synex')) {
      state.wakeRecognition.stop();
      startVoice();
    }
  };
  state.wakeRecognition.onend = () => {
    if (state.settings.wakeWord !== false && !document.getElementById('voice-overlay').classList.contains('active')) {
      try { state.wakeRecognition.start(); } catch(e){}
    }
  };
  try {
    state.wakeRecognition.start();
    state.wakeWordActive = true;
    document.getElementById('wake-indicator').classList.add('listening');
    document.getElementById('wake-label').textContent = 'Listening…';
  } catch(e){}
}

function stopWakeWord() {
  if (state.wakeRecognition) { try { state.wakeRecognition.stop(); } catch(e){} }
  state.wakeWordActive = false;
  document.getElementById('wake-indicator').classList.remove('listening');
  document.getElementById('wake-label').textContent = 'Hey Synex';
}

function toggleWakeWord() {
  if (state.wakeWordActive) { stopWakeWord(); state.settings.wakeWord = false; }
  else { startWakeWord(); state.settings.wakeWord = true; }
  localStorage.setItem('synex_settings', JSON.stringify(state.settings));
  applySettingToggles();
}

// ── Voice mode ──
function startVoice() {
  if (!('webkitSpeechRecognition' in window) && !('SpeechRecognition' in window)) {
    showToast('Voice not supported in this browser'); return;
  }
  stopWakeWord();
  document.getElementById('voice-overlay').classList.add('active');
  document.getElementById('voice-status').textContent = 'Listening…';
  document.getElementById('voice-transcript').textContent = '';

  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  state.voiceRecognition = new SR();
  state.voiceRecognition.continuous = false;
  state.voiceRecognition.interimResults = true;
  state.voiceRecognition.lang = 'en-US';

  state.voiceRecognition.onresult = (e) => {
    const t = Array.from(e.results).map(r => r[0].transcript).join('');
    document.getElementById('voice-transcript').textContent = t;
    if (e.results[e.results.length - 1].isFinal) {
      document.getElementById('voice-status').textContent = 'Processing…';
    }
  };

  state.voiceRecognition.onend = () => {
    const t = document.getElementById('voice-transcript').textContent.trim();
    if (t) {
      closeVoice();
      document.getElementById('message-input').value = t;
      setTimeout(sendMessage, 200);
    } else {
      document.getElementById('voice-status').textContent = 'No speech detected. Try again.';
      setTimeout(() => { try { state.voiceRecognition.start(); } catch(e){} }, 1000);
    }
  };

  state.voiceRecognition.onerror = (e) => {
    document.getElementById('voice-status').textContent = 'Error: ' + e.error;
    setTimeout(closeVoice, 2000);
  };

  try { state.voiceRecognition.start(); } catch(e) { closeVoice(); }
}

function closeVoice() {
  document.getElementById('voice-overlay').classList.remove('active');
  if (state.voiceRecognition) { try { state.voiceRecognition.stop(); } catch(e){} }
  if (state.settings.wakeWord !== false) {
    setTimeout(startWakeWord, 500);
  }
}

let voiceMuted = false;
function toggleMute() {
  voiceMuted = !voiceMuted;
  if (state.voiceRecognition) {
    if (voiceMuted) { try { state.voiceRecognition.stop(); } catch(e){} }
    else { try { state.voiceRecognition.start(); } catch(e){} }
  }
  document.getElementById('voice-status').textContent = voiceMuted ? 'Muted' : 'Listening…';
}

// ── TTS ──
function speak(text) {
  if (!state.synth || state.settings.autoRead !== true) return;
  state.synth.cancel();
  const plain = text.replace(/<[^>]+>/g,'').replace(/```[\s\S]*?```/g,'[code block]').replace(/#{1,6} /g,'');
  const utt = new SpeechSynthesisUtterance(plain.slice(0, 500));
  utt.rate = 1.0; utt.pitch = 1;
  state.synth.speak(utt);
}

// ── Chat ──
function handleKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
}

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 160) + 'px';
}

function updateCharCount() {
  const el = document.getElementById('message-input');
  const count = el.value.length;
  const cc = document.getElementById('char-count');
  if (count > 0) { cc.style.display='block'; cc.textContent = count + ' chars'; }
  else cc.style.display='none';
}

function clearInput() {
  document.getElementById('message-input').value = '';
  document.getElementById('message-input').style.height = 'auto';
  state.attachments = [];
  document.getElementById('file-preview-area').innerHTML = '';
  updateCharCount();
}

function quickPrompt(text) {
  document.getElementById('message-input').value = text;
  document.getElementById('message-input').focus();
  autoResize(document.getElementById('message-input'));
}

function toggleDeepThink() {
  state.deepThink = !state.deepThink;
  state.settings.deepThink = state.deepThink;
  localStorage.setItem('synex_settings', JSON.stringify(state.settings));
  updateThinkBtn();
}

function updateThinkBtn() {
  const btn = document.getElementById('think-btn');
  btn.style.color = state.deepThink ? 'var(--gold)' : '';
  btn.style.borderColor = state.deepThink ? 'rgba(201,168,76,0.4)' : '';
  btn.textContent = state.deepThink ? '🧠 Thinking…' : '🧠 Think';
}

function toggleWebSearch() {
  state.webSearch = !state.webSearch;
  state.settings.webSearch = state.webSearch;
  localStorage.setItem('synex_settings', JSON.stringify(state.settings));
  updateWebBtn();
}

function updateWebBtn() {
  const btn = document.getElementById('web-btn');
  btn.style.color = state.webSearch ? 'var(--accent)' : 'var(--text-muted)';
}

// ── File handling ──
function handleFiles(input) {
  Array.from(input.files).forEach(file => {
    state.attachments.push(file);
    addFileChip(file);
  });
  input.value = '';
}

function addFileChip(file) {
  const area = document.getElementById('file-preview-area');
  const chip = document.createElement('div');
  chip.className = 'file-chip';
  const icon = file.type.startsWith('image/') ? '🖼️' : file.type.includes('pdf') ? '📄' : '📎';
  chip.innerHTML = `${icon} ${file.name.slice(0,20)}${file.name.length>20?'…':''} <span class="file-chip-remove" onclick="removeFile('${file.name}',this)">×</span>`;
  area.appendChild(chip);
}

function removeFile(name, el) {
  state.attachments = state.attachments.filter(f => f.name !== name);
  el.parentElement.remove();
}

// ── Send message ──
async function sendMessage() {
  const input = document.getElementById('message-input');
  const text = input.value.trim();
  if (!text && !state.attachments.length) return;
  if (state.isTyping) return;

  hideEmptyState();
  showSuggestions();

  // Add user message
  const userContent = buildUserContent(text);
  addMessage('user', userContent, text);
  state.messages.push({ role: 'user', content: text || '[file attached]' });

  clearInput();
  const convTitle = text.slice(0, 40) || 'File conversation';
  if (!state.currentConvId) startNewConversation(convTitle);
  document.getElementById('topbar-title').textContent = convTitle;

  // Show typing
  const typingId = showTyping();
  state.isTyping = true;

  try {
    const response = await callAI(text);
    removeTyping(typingId);
    addMessage('assistant', formatResponse(response), response);
    state.messages.push({ role: 'assistant', content: response });
    saveConversation(convTitle);
    speak(response);
  } catch(err) {
    removeTyping(typingId);
    const errMsg = '⚠️ ' + (err.message || 'Something went wrong. Please check your API key in Settings.');
    addMessage('assistant', errMsg, errMsg);
  }
  state.isTyping = false;
}

function buildUserContent(text) {
  let html = '';
  if (state.attachments.length) {
    state.attachments.forEach(f => { html += `<div style="font-size:11px;color:var(--gold);margin-bottom:4px">📎 ${f.name}</div>`; });
  }
  if (text) html += escapeHtml(text).replace(/\n/g,'<br>');
  return html;
}

// ── AI Call ──
async function callAI(userText) {
  const apiKey = state.apiKey || localStorage.getItem('synex_api_key') || '';
  
  if (!apiKey) {
    return getMockResponse(userText);
  }

  const personality = document.getElementById('personality')?.value || 'assistant';
  const respLen = document.getElementById('resp-len')?.value || 'balanced';
  const temp = parseFloat(document.getElementById('temp-slider')?.value || '0.7');

  const systemPrompt = buildSystemPrompt(personality, respLen);
  const messages = buildMessages(userText);

  const body = {
    model: 'claude-sonnet-4-6',
    max_tokens: 4096,
    temperature: temp,
    system: systemPrompt,
    messages: messages
  };

  const res = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'x-api-key': apiKey, 'anthropic-version': '2023-06-01' },
    body: JSON.stringify(body)
  });

  if (!res.ok) {
    const err = await res.json().catch(()=>({}));
    throw new Error(err.error?.message || `API error ${res.status}`);
  }

  const data = await res.json();
  return data.content?.[0]?.text || 'No response received.';
}

function buildSystemPrompt(personality, length) {
  const personas = {
    assistant: 'You are My Synex, a highly capable, elegant AI assistant. Be helpful, precise, and thorough.',
    tutor: 'You are My Synex, an expert tutor. Explain clearly, use examples, and check understanding.',
    creative: 'You are My Synex, a creative AI. Think imaginatively, use vivid language, and push boundaries.',
    analyst: 'You are My Synex, a sharp analyst. Be data-driven, structured, and give clear insights.',
    coder: 'You are My Synex, an elite programmer. Write clean, well-commented code with explanations.'
  };
  const lengths = {
    concise: 'Keep responses brief and to the point.',
    balanced: 'Balance detail with brevity.',
    detailed: 'Provide thorough, detailed responses.',
    comprehensive: 'Be exhaustive and comprehensive in your responses.'
  };
  let system = personas[personality] || personas.assistant;
  system += ' ' + (lengths[length] || lengths.balanced);
  if (state.deepThink) system += ' Take time to think through complex problems step by step before answering.';
  if (state.webSearch) system += ' If asked about current events or recent information, indicate when information might be outdated.';
  return system;
}

function buildMessages(currentText) {
  const msgs = [];
  const history = state.messages.slice(-20); // last 20 for context
  for (const m of history) {
    if (m.content) msgs.push({ role: m.role, content: m.content });
  }
  // If last message already has current text, don't duplicate
  if (!msgs.length || msgs[msgs.length-1].content !== currentText) {
    msgs.push({ role: 'user', content: currentText });
  }
  return msgs;
}

// ── Mock responses (when no API key) ──
function getMockResponse(text) {
  const t = text.toLowerCase();
  if (t.includes('hello') || t.includes('hi')) {
    return "Hello! I'm My Synex, your intelligent AI companion. I'm ready to help you with anything — coding, writing, analysis, translation, and much more.\n\n**To unlock my full capabilities**, add your Anthropic API key in ⚙️ Settings. Until then, I'll do my best to assist you!\n\nWhat would you like to explore today?";
  }
  if (t.includes('code') || t.includes('python') || t.includes('javascript')) {
    return "Here's a code example:\n\n```python\ndef hello_synex():\n    \"\"\"My Synex AI Demo\"\"\"\n    message = \"Hello from My Synex!\"\n    print(f\"🤖 {message}\")\n    return message\n\nresult = hello_synex()\nprint(f\"Result: {result}\")\n```\n\nThis demonstrates a simple Python function. Want me to help with something more specific? Add your API key in Settings for full AI responses!";
  }
  if (t.includes('image') || t.includes('generate') || t.includes('draw')) {
    return "🎨 **Image Generation** is active!\n\nTo generate an image, I'll create a detailed prompt and use the image generation pipeline.\n\n**Your prompt:** " + text + "\n\n*Note: Add your API key in Settings for real AI-powered image generation. The image generation feature will create stunning visuals based on your description.*";
  }
  if (t.includes('translate')) {
    return "🌐 **Translation Feature**\n\nI can translate between 100+ languages with cultural context and nuance.\n\nAdd your Anthropic API key in ⚙️ Settings to activate full translation capabilities with:\n- Formal/informal variants\n- Cultural context notes\n- Pronunciation guides\n- Back-translation verification";
  }
  return `**My Synex** is processing your request: *"${text.slice(0,80)}${text.length>80?'…':''}"*\n\nI'm your ultra-intelligent AI companion, capable of:\n\n- 🧠 **Deep reasoning** and complex analysis\n- 💻 **Code generation** in any language\n- 🎨 **Image generation** from descriptions\n- 🌐 **Translation** in 100+ languages\n- 📄 **Document analysis** and summarization\n- 🔬 **Research** with real-time web search\n\n**To unlock full AI responses**, please add your Anthropic API key in ⚙️ Settings. You can get one at [anthropic.com](https://anthropic.com).`;
}

// ── DOM helpers ──
function hideEmptyState() {
  const e = document.getElementById('empty-state');
  if (e) e.style.display = 'none';
}

function showSuggestions() {
  document.getElementById('sugg-chips').style.display = 'flex';
}

function addMessage(role, htmlContent, rawText) {
  const chatArea = document.getElementById('chat-area');
  const wrapper = document.createElement('div');
  wrapper.className = `msg-wrapper ${role} fade-in`;

  const now = new Date().toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});

  if (role === 'assistant') {
    wrapper.innerHTML = `
      <div class="msg-avatar">✦</div>
      <div>
        <div class="msg-bubble">${htmlContent}</div>
        <div class="msg-meta">
          <span class="msg-time">${now}</span>
          <button class="msg-action-btn" onclick="copyText(this,'${encodeURIComponent(rawText||'')}')">Copy</button>
          <button class="msg-action-btn" onclick="speakText('${encodeURIComponent(rawText||'')}')">🔊</button>
          <button class="msg-action-btn" onclick="regenerate()">↻ Redo</button>
        </div>
      </div>`;
  } else {
    wrapper.innerHTML = `
      <div>
        <div class="msg-bubble">${htmlContent}</div>
        <div class="msg-meta" style="justify-content:flex-end">
          <span class="msg-time">${now}</span>
          <button class="msg-action-btn" onclick="editMessage(this,'${encodeURIComponent(rawText||'')}')">Edit</button>
        </div>
      </div>`;
  }

  chatArea.appendChild(wrapper);
  chatArea.scrollTop = chatArea.scrollHeight;

  // Add copy buttons to code blocks
  wrapper.querySelectorAll('pre').forEach(pre => {
    const wrap = document.createElement('div');
    wrap.className = 'code-wrap';
    pre.parentNode.insertBefore(wrap, pre);
    wrap.appendChild(pre);
    const btn = document.createElement('button');
    btn.className = 'copy-code-btn';
    btn.textContent = 'Copy';
    btn.onclick = () => { navigator.clipboard.writeText(pre.textContent); btn.textContent='Copied!'; setTimeout(()=>btn.textContent='Copy',2000); };
    wrap.appendChild(btn);
  });

  // Make images clickable
  wrapper.querySelectorAll('img').forEach(img => {
    img.style.cursor = 'pointer';
    img.onclick = () => openImgModal(img.src);
  });
}

function showTyping() {
  const chatArea = document.getElementById('chat-area');
  const wrapper = document.createElement('div');
  const id = 'typing_' + Date.now();
  wrapper.id = id;
  wrapper.className = 'msg-wrapper assistant fade-in';
  wrapper.innerHTML = `<div class="msg-avatar">✦</div><div class="msg-bubble"><div class="typing-dots"><span></span><span></span><span></span></div></div>`;
  chatArea.appendChild(wrapper);
  chatArea.scrollTop = chatArea.scrollHeight;
  return id;
}

function removeTyping(id) {
  const el = document.getElementById(id);
  if (el) el.remove();
}

// ── Format response ──
function formatResponse(text) {
  if (!text) return '';
  let html = escapeHtml(text);

  // Code blocks
  html = html.replace(/```(\w*)\n?([\s\S]*?)```/g, (_, lang, code) => {
    return `<pre><code class="lang-${lang}">${code.trim()}</code></pre>`;
  });
  // Inline code
  html = html.replace(/`([^`]+)`/g, '<code>$1</code>');
  // Headers
  html = html.replace(/^### (.+)$/gm, '<h3>$1</h3>');
  html = html.replace(/^## (.+)$/gm, '<h2>$1</h2>');
  html = html.replace(/^# (.+)$/gm, '<h1>$1</h1>');
  // Bold
  html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  // Italic
  html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
  // Links
  html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" style="color:var(--accent);text-decoration:underline">$1</a>');
  // Lists
  html = html.replace(/^- (.+)$/gm, '<li>$1</li>');
  html = html.replace(/^\d+\. (.+)$/gm, '<li>$1</li>');
  html = html.replace(/((<li>.*<\/li>\n?)+)/g, '<ul>$1</ul>');
  // Paragraphs
  html = html.replace(/\n\n/g, '</p><p>');
  html = html.replace(/\n/g, '<br>');
  if (!html.startsWith('<')) html = '<p>' + html + '</p>';

  if (state.deepThink) {
    html = `<div class="think-block">🧠 Deep analysis engaged…</div>` + html;
  }
  return html;
}

function escapeHtml(text) {
  return text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ── Actions ──
function copyText(btn, encoded) {
  const text = decodeURIComponent(encoded);
  navigator.clipboard.writeText(text).then(() => {
    btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = 'Copy', 2000);
  });
}

function speakText(encoded) {
  const text = decodeURIComponent(encoded);
  if (state.synth) {
    state.synth.cancel();
    const utt = new SpeechSynthesisUtterance(text.slice(0,500));
    utt.rate = 1.0;
    state.synth.speak(utt);
  }
}

function editMessage(btn, encoded) {
  const text = decodeURIComponent(encoded);
  document.getElementById('message-input').value = text;
  document.getElementById('message-input').focus();
  autoResize(document.getElementById('message-input'));
}

async function regenerate() {
  if (!state.messages.length) return;
  // Remove last assistant message
  const msgs = state.messages;
  if (msgs[msgs.length-1]?.role === 'assistant') {
    state.messages.pop();
    document.querySelector('.msg-wrapper.assistant:last-child')?.remove();
  }
  const lastUser = msgs.filter(m=>m.role==='user').pop();
  if (!lastUser) return;

  const typingId = showTyping();
  state.isTyping = true;
  try {
    const response = await callAI(lastUser.content);
    removeTyping(typingId);
    addMessage('assistant', formatResponse(response), response);
    state.messages.push({ role: 'assistant', content: response });
  } catch(err) {
    removeTyping(typingId);
    addMessage('assistant', '⚠️ ' + err.message, err.message);
  }
  state.isTyping = false;
}

// ── History / Conversations ──
function startNewConversation(title) {
  state.currentConvId = Date.now().toString();
  const conv = { id: state.currentConvId, title: title.slice(0,40), date: new Date().toLocaleDateString(), messages: [] };
  state.history.unshift(conv);
  if (state.history.length > 50) state.history.pop();
  renderHistory();
}

function saveConversation(title) {
  const conv = state.history.find(h => h.id === state.currentConvId);
  if (conv) {
    conv.messages = [...state.messages];
    conv.title = title.slice(0,40);
    localStorage.setItem('synex_history', JSON.stringify(state.history));
  }
}

function loadConversation(id) {
  const conv = state.history.find(h => h.id === id);
  if (!conv) return;
  state.currentConvId = id;
  state.messages = [...(conv.messages || [])];
  hideEmptyState();
  const chatArea = document.getElementById('chat-area');
  // Remove all msg-wrappers
  chatArea.querySelectorAll('.msg-wrapper').forEach(el=>el.remove());
  state.messages.forEach(m => addMessage(m.role, formatResponse(m.content), m.content));
  document.getElementById('topbar-title').textContent = conv.title;
  showSuggestions();
}

function renderHistory() {
  const list = document.getElementById('history-list');
  list.innerHTML = state.history.slice(0,20).map(h =>
    `<div class="history-item" onclick="loadConversation('${h.id}')" title="${escapeHtml(h.title||'')}">
      💬 ${escapeHtml(h.title||'Conversation')}</div>`
  ).join('');
}

function newChat() {
  state.messages = [];
  state.currentConvId = null;
  state.attachments = [];
  document.getElementById('file-preview-area').innerHTML = '';
  const chatArea = document.getElementById('chat-area');
  chatArea.querySelectorAll('.msg-wrapper').forEach(el=>el.remove());
  const empty = document.getElementById('empty-state');
  if (empty) empty.style.display = '';
  document.getElementById('sugg-chips').style.display = 'none';
  document.getElementById('topbar-title').textContent = 'New Conversation';
  clearInput();
}

// ── Export ──
function exportChat(format) {
  const msgs = state.messages;
  if (!msgs.length) { showToast('No messages to export'); return; }
  let content = '';
  const title = document.getElementById('topbar-title').textContent;
  const date = new Date().toLocaleString();

  if (format === 'txt') {
    content = `My Synex Chat Export\n${title}\n${date}\n${'─'.repeat(50)}\n\n`;
    msgs.forEach(m => content += `[${m.role.toUpperCase()}]\n${m.content}\n\n`);
    download(content, 'synex-chat.txt', 'text/plain');
  } else if (format === 'md') {
    content = `# My Synex — ${title}\n*Exported: ${date}*\n\n---\n\n`;
    msgs.forEach(m => content += `**${m.role === 'user' ? '🧑 You' : '✦ Synex'}**\n\n${m.content}\n\n---\n\n`);
    download(content, 'synex-chat.md', 'text/markdown');
  } else if (format === 'json') {
    content = JSON.stringify({ title, date, messages: msgs }, null, 2);
    download(content, 'synex-chat.json', 'application/json');
  } else if (format === 'html') {
    content = `<!DOCTYPE html><html><head><title>My Synex — ${title}</title><style>body{background:#080808;color:#f0f0f0;font-family:sans-serif;max-width:800px;margin:40px auto;padding:20px}.msg{margin:16px 0;padding:14px;border-radius:12px}.user{background:rgba(180,160,255,0.15)}.assistant{background:#141414}h1{color:#b4a0ff}</style></head><body><h1>✦ My Synex</h1><h2>${title}</h2><p style="color:#555">${date}</p>`;
    msgs.forEach(m => { content += `<div class="msg ${m.role}"><strong>${m.role==='user'?'You':'Synex'}</strong><p>${escapeHtml(m.content)}</p></div>`; });
    content += '</body></html>';
    download(content, 'synex-chat.html', 'text/html');
  }
  closePanel('export-panel');
  showToast('Chat exported!');
}

function download(content, filename, type) {
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([content], {type}));
  a.download = filename;
  a.click();
}

// ── Memory ──
function showMemory() {
  const mems = JSON.parse(localStorage.getItem('synex_memory') || '[]');
  if (!mems.length) { showToast('No memories stored yet'); return; }
  quickPrompt('My memory contains: ' + mems.slice(0,5).join(', '));
}

// ── Templates ──
const templates = {
  email: 'Write a professional email to [recipient] about [topic]. The tone should be [formal/friendly].',
  report: 'Create a detailed report on [topic] covering: introduction, key findings, analysis, and recommendations.',
  code: 'Write [language] code to [task]. Include comments and error handling.',
  essay: 'Write a [length]-word essay about [topic] with an introduction, 3 body paragraphs, and conclusion.',
};
function insertTemplate(type) {
  const t = templates[type] || templates.email;
  document.getElementById('message-input').value = t;
  document.getElementById('message-input').focus();
  autoResize(document.getElementById('message-input'));
}

// ── Panels ──
function openPanel(id) { document.getElementById(id).classList.add('active'); }
function closePanel(id) { document.getElementById(id).classList.remove('active'); }

// Close panels on overlay click
document.querySelectorAll('.panel-overlay').forEach(el => {
  el.addEventListener('click', function(e) { if (e.target === this) this.classList.remove('active'); });
});

// ── Toast ──
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

// ── Image modal ──
function openImgModal(src) {
  document.getElementById('img-modal-src').src = src;
  document.getElementById('img-modal').classList.add('active');
}
function closeImgModal() { document.getElementById('img-modal').classList.remove('active'); }

// ── Sidebar toggle (mobile) ──
function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
}

// ── Keyboard shortcuts ──
document.addEventListener('keydown', e => {
  if ((e.ctrlKey || e.metaKey) && e.key === 'k') { e.preventDefault(); document.getElementById('message-input').focus(); }
  if ((e.ctrlKey || e.metaKey) && e.key === '/') { e.preventDefault(); openPanel('settings-panel'); }
  if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.key === 'V') { e.preventDefault(); startVoice(); }
  if (e.key === 'Escape') {
    document.querySelectorAll('.panel-overlay.active').forEach(p=>p.classList.remove('active'));
    if (document.getElementById('voice-overlay').classList.contains('active')) closeVoice();
    if (document.getElementById('img-modal').classList.contains('active')) closeImgModal();
  }
});

// ── Suggestions click ──
document.querySelectorAll('.sugg-chip').forEach(chip => {
  chip.addEventListener('click', () => {
    document.getElementById('message-input').value = chip.textContent;
    sendMessage();
  });
});

// ── Start ──
init();
